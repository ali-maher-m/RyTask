# syntax=docker/dockerfile:1
# Builds the Next.js web app.

FROM node:22-alpine AS base
ENV PNPM_HOME=/pnpm
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable
WORKDIR /repo

FROM base AS build
# NEXT_PUBLIC_* is inlined into the client bundle at build time, so the API URL the browser
# uses must be present here (a runtime env on the container is too late). Defaults to empty
# (relative same-origin) for non-Docker builds; the compose stack passes http://localhost:3001.
ARG NEXT_PUBLIC_API_URL=
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
COPY . .
RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --frozen-lockfile
RUN pnpm build
RUN pnpm --filter @rytask/web --prod deploy /app

FROM base AS runtime
ENV NODE_ENV=production
WORKDIR /app
COPY --from=build /app /app
EXPOSE 3000
# Run the real Next bin directly: `pnpm start` trips pnpm 11's verify-deps check, which tries to
# purge node_modules and aborts with no TTY; the `.bin/next` shim is a shell script, not JS.
CMD ["node", "node_modules/next/dist/bin/next", "start"]
