{
  "name": "@rytask/sdk",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "gen:sdk": "openapi-typescript ../../specs/001-core-work-loop/contracts/openapi.yaml -o src/generated.ts && biome format --write src/generated.ts"
  },
  "dependencies": {
    "@rytask/contracts": "workspace:*"
  },
  "devDependencies": {
    "openapi-typescript": "7.13.0",
    "typescript": "5.7.3"
  }
}
