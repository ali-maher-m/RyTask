# ============================================
# RyTask production environment (docker-compose.production.yml)
# ============================================
# On Dokploy: paste this (with real values) into the service's Environment tab —
# Dokploy writes it to `.env` next to the compose file, where compose interpolates it.
# Locally: cp .env.production.example .env
#
# Generate secrets:
#   JWT_SECRET            openssl rand -hex 32
#   POSTGRES_PASSWORD     openssl rand -hex 24   (keep alphanumeric — it is embedded in DATABASE_URL)
#   REDIS_PASSWORD        openssl rand -hex 24
#   SLACK_TOKEN_ENC_KEY   openssl rand -base64 32
# ============================================

# ----- Database (internal only; never exposed) -----
POSTGRES_USER=rytask
POSTGRES_PASSWORD=CHANGE-ME-openssl-rand-hex-24
POSTGRES_DB=rytask

# ----- Redis (internal only) -----
REDIS_PASSWORD=CHANGE-ME-openssl-rand-hex-24

# ----- Auth (production boot guard: required, non-default, >= 32 chars) -----
JWT_SECRET=CHANGE-ME-openssl-rand-hex-32

# ----- Public origins (must match the domains you map in Dokploy) -----
# Changing PUBLIC_API_URL requires a REBUILD of the web image (it is baked
# into the browser bundle at build time), not just a restart.
PUBLIC_WEB_URL=https://app.example.com
PUBLIC_API_URL=https://api.example.com

# ----- First boot -----
# No env needed: visit ${PUBLIC_WEB_URL}/setup once the stack is up. The
# first-run page creates the org + owner account and self-closes after.
# (/register stays "invite-only" until you enable public signup in
# Settings -> Organization — it is a per-org DATABASE setting, not an env var.)

# ----- Rate limiting (per 60s window; code defaults) -----
#THROTTLE_MAX_REQUESTS=300
#AUTH_THROTTLE_MAX_REQUESTS=20

# ----- Backups (pg_dump sidecar into the `dbbackups` volume) -----
#BACKUP_SCHEDULE_HOURS=6
#BACKUP_RETENTION_DAYS=30

# ----- Slack capture (optional — leave empty to keep Slack inert) -----
# All three of CLIENT_ID/CLIENT_SECRET/SIGNING_SECRET must be set together,
# and then SLACK_TOKEN_ENC_KEY (base64 32 bytes) becomes REQUIRED at boot.
# Slack app redirect URL: ${PUBLIC_API_URL}/integrations/slack/oauth/callback
#SLACK_CLIENT_ID=
#SLACK_CLIENT_SECRET=
#SLACK_SIGNING_SECRET=
#SLACK_TOKEN_ENC_KEY=

# ----- GitHub linking (optional) -----
# Webhook-secret encryption key; falls back to SLACK_TOKEN_ENC_KEY when unset.
#GITHUB_TOKEN_ENC_KEY=
