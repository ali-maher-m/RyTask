# Copy to `.env` and adjust. ONLY `.env.example` is committed (ARCHITECTURE §15);
# the real `.env` is edited locally and is git-ignored.

# --- API ---
PORT=3001
APP_VERSION=0.0.0

# --- Database (PostgreSQL 16) ---
DATABASE_URL=postgres://rytask:rytask@localhost:5432/rytask

# --- Redis 7 (queues, cache, pub/sub, rate limits) ---
REDIS_URL=redis://localhost:6379

# --- Object storage (MinIO / S3-compatible) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=rytask
S3_SECRET_KEY=rytasksecret
S3_BUCKET=rytask

# --- Email (Mailhog in dev: SMTP :1025, UI :8025) ---
SMTP_HOST=localhost
SMTP_PORT=1025

# --- Auth / sessions (M0) ---
# Access tokens are stateless JWTs. Default HS256 uses ONE shared secret (api+worker
# share an image). To use RS256 instead, set JWT_PRIVATE_KEY and JWT_PUBLIC_KEY (PEM).
JWT_SECRET=dev-insecure-jwt-secret-change-me
JWT_ISSUER=rytask
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=
ACCESS_TOKEN_TTL_SECONDS=900        # hard-capped at 900 (15 min, SC-003)
REFRESH_TOKEN_TTL_SECONDS=2592000   # 30 days
APP_BASE_URL=http://localhost:3000  # used to build verify/reset/invite links
ALLOW_PUBLIC_SIGNUP=false           # invite-only by default (D8)

# --- Password hashing (argon2id, NFR-SEC-002) ---
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# --- Rate limiting & brute-force (Redis-backed, D12) ---
THROTTLE_WINDOW_SECONDS=60
THROTTLE_MAX_REQUESTS=300
AUTH_THROTTLE_WINDOW_SECONDS=60
AUTH_THROTTLE_MAX_REQUESTS=20
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_SECONDS=900

# --- Worker ---
# Set WORKER=1 to start the background worker instead of the HTTP API (same image).
# WORKER=1

# --- Slack capture (M3, D2) ---
# Leave these UNSET to keep Slack inert (the noop adapter logs instead of calling Slack);
# `docker compose up` still works with zero Slack config (Principle VII). Set them to wire
# the real Slack app: credentials come from your Slack app's "Basic Information" + "OAuth".
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=
# Where Slack returns the OAuth consent (must match the app's redirect URL).
# SLACK_OAUTH_CALLBACK_URL=http://localhost:3001/integrations/slack/oauth/callback
# 32-byte key (base64) used to encrypt per-install bot tokens at rest (AES-256-GCM).
# Generate with: openssl rand -base64 32
# SLACK_TOKEN_ENC_KEY=

# --- MCP server (M3, D3) ---
# The public base URL the MCP HTTP/SSE transport is reachable at (shown on the Agent-access
# page so a human can connect an MCP client). Leave unset for stdio-only / local use.
# MCP_PUBLIC_URL=http://localhost:3001/mcp

# --- Web ---
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
# The MCP endpoint surfaced to the browser on the Agent-access page (M3, US6).
# NEXT_PUBLIC_MCP_URL=http://localhost:3001/mcp
