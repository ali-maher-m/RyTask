{
  "name": "rytask",
  "version": "0.0.0",
  "private": true,
  "description": "RyTask — open-source, self-hostable project management & issue tracker (monorepo)",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "test:coverage": "turbo run test -- --coverage",
    "check:required-tests": "tsx scripts/check-required-tests.ts",
    "check:mcp-parity": "tsx scripts/check-mcp-parity.ts",
    "check:design-tokens": "tsx scripts/check-design-tokens.ts",
    "check:boundaries": "depcruise apps packages --config packages/config/dependency-cruiser.cjs",
    "sync:tokens": "tsx scripts/sync-tokens.ts",
    "db:generate": "pnpm --filter @rytask/db generate",
    "db:migrate": "pnpm --filter @rytask/db migrate",
    "db:seed": "pnpm --filter @rytask/db seed"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "22.10.5",
    "dependency-cruiser": "16.8.0",
    "tsx": "4.19.2",
    "turbo": "2.3.3",
    "typescript": "5.7.3"
  }
}
